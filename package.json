{
	"name": "workspace",
	"private": true,
	"type": "module",
	"scripts": {
		"ensure-deps": "node ./scripts/ensure-deps.mjs",
		"dev": "tsx watch server.ts",
		"start": "tsx server.ts",
		"typecheck": "tsc --noEmit",
		"test": "npm run -s ensure-deps && tsx --test",
		"test:smoke:advice": "npm run -s ensure-deps && RUN_ADVICE_OPENAI_SMOKE=1 tsx --test app/features/advice/advice-openai.smoke.test.ts",
		"lint": "biome lint .",
		"format": "biome format .",
		"check": "npm run -s ensure-deps && biome check ."
	},
	"dependencies": {
		"openai": "^6.29.0",
		"remix": "^3.0.0-alpha.4",
		"tsx": "^4.20.5"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/node": "^24.5.2",
		"typescript": "^5.9.2"
	},
	"overrides": {
		"@remix-run/component": "0.5.0",
		"@remix-run/interaction": "0.5.0"
	}
}
